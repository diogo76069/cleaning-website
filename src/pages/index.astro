---
import Layout from "../layouts/Layout.astro";
import ServiceCard from "../components/ServiceCard.astro";
import TrustCard from "../components/TrustCard.astro";
import Icon1 from "../assets/Icon1.webp";
import Icon2 from "../assets/Icon2.webp";
import Icon3 from "../assets/Icon3.webp";
import Icon4 from "../assets/Icon4.webp";

const pageTitle = "K&H Gebäudereinigung";
---

<Layout pageTitle={pageTitle}>
  <!-- Hero -->
  <section class="bg-white py-24 border-b border-gray-200">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 items-center">
      <div>
        <h1 class="text-5xl font-bold mb-6">Wir bringen Glanz in Ihre Räume</h1>
        <p class="text-lg text-gray-600 mb-8">
          Reinigungsservice für Privat- und Gewerbekunden in Worms und Umgebung
        </p>
        <div class="flex justify-center">
          <a
            href="/contact"
            class="relative inline-block overflow-hidden p-6 font-semibold
            text-white bg-blue-100 rounded-lg group w-sm text-center">
            <span
              class="absolute inset-0 bg-[#004e7a] translate-x-0
                group-hover:translate-x-full transition-transform duration-500 ease-in-out"
            ></span>

            <span
              class="relative z-10 group-hover:text-[#004e7a]
                transition-colors duration-500 text-xl">
              Jetzt anfragen
            </span>
          </a>
        </div>
      </div>
    </div>
  </section>
  <section class="py-24 bg-gray-50 border-b border-gray-200">
    <div class="max-w-5xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">Über uns</h2>

      <p class="text-lg text-gray-600 max-w-3xl mx-auto mb-10 leading-relaxed">
        Sauberkeit ist unsere Leidenschaft. Mit maßgeschneiderten
        Reinigungslösungen für Büros, Treppenhäuser, Praxen, Gewerbeobjekte
        sowie Privathaushalte garantieren wir höchste Qualität und Sorgfalt. Ob
        Unternehmen oder Privatkunde - wir arbeiten gründlich und zuverlässig.
      </p>

      <a
        href="/about"
        class="group relative inline-flex items-center
          justify-center overflow-hidden px-3 py-3
          text-[#004e7a] font-semibold transition-all
          duration-300 hover:opacity-80">
        <span class="transition-all duration-300
          group-hover:mr-2"
          >Weitere Informationen</span
        >
        <span
          class="transform -translate-x-3 opacity-0
        transition-all duration-300 group-hover:translate-x-0
        group-hover:opacity-100"
          >→</span
        >
      </a>
    </div>
  </section>
  <section class="py-24 bg-white border-b border-gray-200">
    <div class="max-w-6xl mx-auto">
      <!-- Section Header -->
      <div class="mb-16 max-w-2xl">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Unsere Leistungen</h2>
        <p class="text-gray-600">
          Wir bieten ein breites Spektrum an Reinigungsdienstleistungen für
          unterschiedliche Anforderungen.
        </p>
      </div>

      <!-- Grid -->
      <div class="grid gap-12 md:grid-cols-2 lg:grid-cols-3 mb-12">
        <ServiceCard
          title="Gebäudereinigung & Büroreinigung"
          description="Wir sorgen für saubere, hygienische und gepflegte Arbeitsumgebungen, damit sich Mitarbeiter und Kunden gleichermaßen wohlfühlen."
        />

        <ServiceCard
          title="Treppen- & Treppenhausreinigung"
          description="Mit regelmäßiger und gründlicher Reinigung gewährleisten wir einen gepflegten ersten Eindruck vom Eingangsbereich bis ins oberste Stockwerk."
        />

        <ServiceCard
          title="Praxisreinigung"
          description="Wir reinigen Praxen nach höchsten Hygiene- und Sauberkeitsstandards für ein sicheres Umfeld für Patienten und Personal."
        />

        <ServiceCard
          title="Privathaushaltsreinigung"
          description="Wir sorgen für ein sauberes und gepflegtes Zuhause - zuverlässig, gründlich und ganz nach Ihren individuellen Wünschen."
        />

        <ServiceCard
          title="Bauendreinigung"
          description="Nach Bau- oder Renovierungsarbeiten sorgen wir mit einer gründlichen Endreinigung für saubere und bezugsfertige Räumlichkeiten."
        />

        <ServiceCard
          title="Glasreinigung (innen)"
          description="Wir reinigen Fenster und Glasflächen im Innenbereich streifenfrei und sorgen für klare Sicht und einen gepflegten Gesamteindruck."
        />
      </div>

      <!-- Single CTA -->
      <div class="text-center mt-12">
        <a
          href="/services"
          class="group relative inline-flex items-center
          justify-center overflow-hidden px-6 py-3
          text-[#004e7a] font-semibold transition-all
          duration-300 hover:opacity-80">
          <span class="transition-all duration-300
          group-hover:mr-2"
            >Weitere Informationen</span
          >
          <span
            class="transform -translate-x-3 opacity-0
        transition-all duration-300 group-hover:translate-x-0
        group-hover:opacity-100"
            >→</span
          >
        </a>
      </div>
    </div>
  </section>
  <section class="py-24 bg-white">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2">
      <div>
        <h1 class="text-3xl md:text-3xl font-bold mb-8">
          Was uns als Reinigungsunternehmen auszeichnet
        </h1>
        <p class="text-gray-600 text-lg">
          Im Mittelpunkt unserer Arbeit stehen Ihre Anforderungen und
          Erwartungen. Wir legen großen Wert auf eine zuverlässige Ausführung,
          transparente Abläufe und eine partnerschaftliche Zusammenarbeit.
        </p>
      </div>
      <div class="grid md:grid-cols-2 gap-x-6 gap-y-8">
        <TrustCard
          title="Vertrauen"
          description="Transparenter Umgang mit unseren Kunden"
          image={Icon1}
        />
        <TrustCard
          title="Qualität"
          description="Gründliche und sorgfältige Reinigung"
          image={Icon2}
        />
        <TrustCard
          title="Zuverlässigkeit"
          description="Pünktliche und planbare Reinigungstermine"
          image={Icon3}
        />
        <TrustCard
          title="Kundennähe"
          description="Persönliche Betreuung und Kommunikation"
          image={Icon4}
        />
      </div>
    </div>
  </section>
</Layout>
