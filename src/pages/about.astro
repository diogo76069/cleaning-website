---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import TrustCard from "../components/TrustCard.astro";
import Icon1 from "../assets/Icon1.webp";
import Icon2 from "../assets/Icon2.webp";
import Icon3 from "../assets/Icon3.webp";
import Icon4 from "../assets/Icon4.webp";

const pageTitle = "Über uns";
const floatingActionsThreshold = 0;
---

<Layout
  pageTitle={pageTitle}
  floatingActionsThreshold={floatingActionsThreshold}>
  <section class="py-24 border-b border-gray-200">
    <div class="max-w-6xl mx-auto">
      <div class="max-w-2xl text-center mx-auto">
        <h1 class="text-4xl md:text-5xl font-bold mb-12">Über uns</h1>
      </div>
      <div class="py-5">
        <h1 class="text-2xl md:text-3xl font-bold mb-6">
          Eine Reinigungsfirma, der Sie vertrauen können
        </h1>

        <p class="text-gray-600 mb-6 leading-relaxed">
          Als familiengeführtes Unternehmen aus Worms stehen wir für Vertrauen,
          Zuverlässigkeit und persönliche Betreuung. Für uns ist Reinigung mehr
          als nur ein Service - sie ist unsere Verantwortung gegenüber unseren
          Kunden und deren Räumlichkeiten.
        </p>

        <p class="text-gray-600 leading-relaxed">
          Unsere Mission ist es, saubere, gepflegte und hygienische Räume zu
          schaffen, in denen sich Menschen wohlfühlen und gerne arbeiten oder
          leben. Mit Engagement, Sorgfalt, und eine hohen Qualitätsanspruch
          setzen wir jeden Auftrag gewissenhaft um - als wäre es unser eigener
          Bereich.
        </p>
      </div>
    </div>
  </section>
  <section class="py-24 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="max-w-2xl mb-14">
        <h2 class="text-2xl md:text-3xl font-bold mb-4">Wofür wir stehen</h2>
        <p class="text-gray-600 leading-relaxed">
          Unsere Arbeit basiert auf klaren Werten, die wir in jedem Auftrag
          leben.
        </p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 xl:grid-cols-4">
        <TrustCard
          title="Vertrauen"
          description="Ein respektvoller und transparenter Umgang mit unseren Kunden bildet die Basis unserer Zusammenarbeit."
          image={Icon1}
        />
        <TrustCard
          title="Qualität"
          description="Wir arbeiten gründlich, sorgfältig und mit dem Anspruch, jedes Objekt in bestem Zustand zu hinterlassen."
          image={Icon2}
        />
        <TrustCard
          title="Zuverlässigkeit"
          description="Wir halten, was wir versprechen, und sind stets pünktlich und verbindlich für Sie da."
          image={Icon3}
        />
        <TrustCard
          title="Kundennähe"
          description="Als familiengeführtes Unternehmen legen wir großen Wert auf persönliche Betreuung und direkte Kommunikation."
          image={Icon4}
        />
      </div>
    </div>
  </section>
</Layout>
