---
import Layout from "../layouts/Layout.astro";
import ServiceCard from "../components/ServiceCard.astro";

const pageTitle = "Unsere Leistungen";
const floatingActionsThreshold = 0;
---

<Layout
  pageTitle={pageTitle}
  floatingActionsThreshold={floatingActionsThreshold}>
  <section class="bg-white max-w-6xl py-24 mx-auto px-6">
    <div class="mb-12">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">Unsere Leistungen</h1>
      <p class="text-lg text-gray-600 font-semibold max-w-2xl">
        Wir bieten ein breites Spektrum an Reinigungsdienstleistungen für
        unterschiedliche Anforderungen.
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid gap-x-8 gap-y-12 md:grid-cols-2 lg:grid-cols-3">
      <!-- Service Cards -->
      <ServiceCard
        title="Gebäudereinigung & Büroreinigung"
        description="Eine saubere Arbeitsumgebung trägt maßgeblich zur Produktivität und zum Wohlbefinden bei. Wir übernehmen die regelmäßige Reinigung von Büroräumen, Sanitäranlagen, Küchenbereichen, Fluren und Gemeinschaftsflächen. Dabei achten wir auf gründliche Bodenreinigung, hygienische Oberflächenpflege und eine zuverlässige Ausführung nach festgelegtem Reinigungsplan."
      />
      <ServiceCard
        title="Treppen- & Treppenhausreinigung"
        description="Das Treppenhaus ist die Visitenkarte eines Gebäudes. Wir reinigen Treppen, Geländer, Handläufe, Eingangsbereiche, Briefkastenanlagen und Gemeinschaftsflächen gründlich und regelmäßig. Durch feste Intervalle sorgen wir dauerhaft für einen gepflegten und einladenden Eindruck – ideal für Hausverwaltungen und Eigentümergemeinschaften."
      />
      <ServiceCard
        title="Praxisreinigung"
        description="In Praxen gelten besonders hohe Hygieneanforderungen. Wir reinigen Behandlungsräume, Wartebereiche, Sanitäranlagen und Empfangsbereiche sorgfältig und nach klaren Hygienestandards. Dabei verwenden wir geeignete Reinigungs- und Desinfektionsmittel, um ein sicheres Umfeld für Patienten und Personal zu gewährleisten."
      />
      <ServiceCard
        title="Privathaushaltsreinigung"
        description="Wir unterstützen Sie im Alltag mit einer zuverlässigen und gründlichen Reinigung Ihres Zuhauses. Ob regelmäßige Reinigung oder intensive Grundpflege – wir reinigen Böden, Bäder, Küchen, Wohnbereiche und Oberflächen sorgfältig und nach Ihren individuellen Wünschen. Diskretion und ein respektvoller Umgang mit Ihrem privaten Umfeld sind für uns selbstverständlich."
      />
      <ServiceCard
        title="Glasreinigung (innen)"
        description="Saubere Glasflächen sorgen für mehr Licht und einen gepflegten Gesamteindruck. Wir reinigen Fenster, Glastüren und sonstige Glasflächen im Innenbereich streifenfrei und sorgfältig. Dabei achten wir auf eine schonende Reinigung der Rahmen und angrenzenden Flächen."
      />
    </div>

    <p
      class="text-lg text-gray-600 font-semibold max-w-2xl text-center mx-auto mt-12">
      Sie finden nicht was Sie suchen? Sprechen Sie uns gerne an. Wir erweitern
      unser Angebot stetig.
    </p>
  </section>

  <!-- Call to Action -->
  <section class="mb-24 py-16 max-w-6xl mx-auto">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-bold mb-6">
        Sie suchen ein pflichtbewusstes Reinigungsunternehmen? Dann sind Sie bei
        uns genau richtig!
      </h2>
      <a
        href="/contact"
        class="relative inline-block overflow-hidden px-12 py-5 font-semibold
            text-white bg-blue-100 rounded-lg group max-w-max text-center">
        <span
          class="absolute inset-0 bg-[#004e7a] translate-x-0
                group-hover:translate-x-full transition-transform duration-500 ease-in-out"
        ></span>

        <span
          class="relative z-10 group-hover:text-[#004e7a]
                transition-colors duration-500">
          Kontakt aufnehmen
        </span>
      </a>
    </div>
  </section>
</Layout>
