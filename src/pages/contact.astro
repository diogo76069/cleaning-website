---
import Layout from "../layouts/Layout.astro";

const pageTitle = "Kontaktieren Sie uns";
---

<Layout pageTitle={pageTitle}>
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-6">
      <!-- Page Heading -->
      <div class="text-center mb-16">
        <h1 class="text-3xl md:text-4xl font-bold mb-4">Contact Us</h1>
        <p class="text-gray-600 max-w-2xl mx-auto">
          Get in touch with us for a free quote or any questions about our
          services. We’ll get back to you as soon as possible.
        </p>
      </div>

      <!-- Content Grid -->
      <div class="grid gap-12 md:grid-cols-2 items-start">
        <!-- Contact Form -->
        <form
          action=""
          method="POST"
          class="space-y-6 bg-white p-8 rounded-xl border border-gray-200 shadow-sm">
          <!-- Name -->
          <div>
            <label
              for="name"
              class="block text-sm font-semibold text-[#004e7a]">
              Name
            </label>
            <input
              id="name"
              name="name"
              type="text"
              required
              class="mt-1 w-full rounded-lg border border-gray-300 px-4 py-2
                   focus:border-[#004e7a] focus:ring-1 focus:ring-[#004e7a]"
            />
          </div>

          <!-- Email -->
          <div>
            <label
              for="email"
              class="block text-sm font-semibold text-[#004e7a]">
              Email
            </label>
            <input
              id="email"
              name="email"
              type="email"
              required
              class="mt-1 w-full rounded-lg border border-gray-300 px-4 py-2
                   focus:border-[#004e7a] focus:ring-1 focus:ring-[#004e7a]"
            />
          </div>

          <!-- Phone -->
          <div>
            <label
              for="phone"
              class="block text-sm font-semibold text-[#004e7a]">
              Phone
            </label>
            <input
              id="phone"
              name="phone"
              type="tel"
              class="mt-1 w-full rounded-lg border border-gray-300 px-4 py-2
                   focus:border-[#004e7a] focus:ring-1 focus:ring-[#004e7a]"
            />
          </div>

          <!-- Message -->
          <div>
            <label
              for="message"
              class="block text-sm font-semibold text-[#004e7a]">
              Message
            </label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="mt-1 w-full rounded-lg border border-gray-300 px-4 py-2
                   focus:border-[#004e7a] focus:ring-1 focus:ring-[#004e7a]"
            ></textarea>
          </div>

          <!-- Privacy Checkbox -->
          <div>
            <label
              class="inline-flex items-center gap-3 cursor-pointer select-none">
              <input type="checkbox" class="peer sr-only" />

              <span
                class="grid size-6 place-items-center rounded-md border border-gray-300
            bg-white transition-all
            peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2
            peer-focus-visible:outline-[#004e7a] peer-checked:border-[#004e7a]
            peer-checked:[&>svg]:opacity-100
            peer-checked:[&>svg]:scale-100">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke-width="3"
                  stroke="currentColor"
                  class="size-4 text-[#004e7a] opacity-0 scale-90 transition"
                  aria-hidden="true">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="m4.5 12.75 6 6 9-13.5"></path>
                </svg>
              </span>

              <span class="text-sm text-gray-600"
                >Ich bestätige, die Datenschutzhinweise zur Kenntnis genommen zu
                haben.</span
              >
            </label>
          </div>

          <!-- Submit -->
          <button
            type="submit"
            class="relative inline-block overflow-hidden px-6 py-3 font-semibold
            text-white bg-blue-100 rounded-lg group w-full text-center">
            <span
              class="absolute inset-0 bg-[#004e7a] translate-x-0
                group-hover:translate-x-full transition-transform duration-500 ease-in-out"
            ></span>

            <span
              class="relative z-10 group-hover:text-[#004e7a]
                transition-colors duration-500 text-xl">
              Jetzt anfragen
            </span>
          </button>
        </form>

        <!-- Contact Info -->
        <div class="space-y-8">
          <div>
            <h2 class="text-2xl font-semibold mb-4">Contact Information</h2>
            <p class="text-gray-600">
              Prefer direct contact? Reach out using the details below.
            </p>
          </div>

          <div class="space-y-8 w-xs">
            <div
              class="bg-white p-4 rounded-2xl shadow-md transition-all duration-300 border border-gray-100
              flex gap-8 hover:shadow-xl hover:-translate-y-1">
              <a
                href="tel:+351123456789"
                class="flex items-center text-[#004e7a]">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="2"
                  stroke="currentColor"
                  class="size-7">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"
                  ></path>
                </svg>
              </a>
              <div class="items-center">
                <span class="text-lg font-semibold text-[#004e7a]"
                  >Our phone number</span
                >

                <p class="text-sm opacity-80 mt-1">+351 123 456 789</p>
              </div>
            </div>
            <div
              class="bg-white p-4 rounded-2xl shadow-md transition-all duration-300 border border-gray-100
              flex gap-8 hover:shadow-xl hover:-translate-y-1">
              <a
                href="mailto:info@k&h.de"
                class="flex items-center text-[#004e7a]">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="2"
                  stroke="currentColor"
                  class="size-6">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"
                  ></path>
                </svg>
              </a>
              <div class="items-center">
                <span class="text-lg font-semibold text-[#004e7a]"
                  >Our email</span
                >

                <p class="text-sm opacity-80 mt-1">info@k&h.de</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
