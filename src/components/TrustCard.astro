---
import { Image } from "astro:assets";
const { title, description, image } = Astro.props;
---

<div class="bg-white shadow-md px-6 py-4 border-2 border-[#004e7a] rounded-xl">
  <div class="flex justify-center items-center">
    <Image src={image} alt={title} class="w-12 h-12 shrink-0" />
  </div>
  <div class="text-center">
    <h2 class="text-xl font-semibold text-[#004e7a] mb-3">{title}</h2>
    <p class="text-gray-600">{description}</p>
  </div>
</div>
