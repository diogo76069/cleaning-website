---
import { Image } from "astro:assets";

const { title, description, image } = Astro.props;
---

<div
  class="bg-white rounded-xl shadow-md overflow-hidden transition hover:-translate-y-1 hover:shadow-xl border border-gray-100 flex h-full">
  {
    image && (
      <div class="w-1/3 min-h-full pl-4 pb-4 pt-4 rounded-xl">
        <Image
          src={image}
          alt={title}
          class="w-full h-full object-cover rounded-xl"
        />
      </div>
    )
  }

  <div class="p-5 flex flex-col flex-1">
    <h2 class="text-lg font-semibold mb-2">{title}</h2>
    <p class="text-gray-600 text-base flex-1">{description}</p>
  </div>
</div>
