---
const { showAfterScroll } = Astro.props;
---

<div
  id="floating-actions"
  class="invisible pointer-events-none flex-col gap-4 fixed right-0 bottom-1/2 z-50 transition-opacity duration-300 opacity-0"
  data-prop={showAfterScroll}>
  <div class="flex flex-col gap-4">
    <!-- Phone -->
    <a
      href="tel:+351900000000"
      class="bg-[#004e7a] text-white p-4 shadow-lg translate-x-38 transition-all duration-900 hover:translate-x-0 rounded-l-lg">
      <div
        class="flex items-center gap-4 hover:translate-x-0 transition-transform duration-900">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="2"
          stroke="currentColor"
          class="size-6">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"
          ></path>
        </svg>
        <span class="font-semibold text-xl">Jetzt anrufen</span>
      </div>
    </a>

    <!-- Email -->
    <a
      href="mailto:hello@example.com"
      class="bg-[#004e7a] text-white p-4 shadow-lg translate-x-38 transition-all duration-900 hover:translate-x-0 rounded-l-lg">
      <div
        class="flex items-center gap-4 hover:translate-x-0 transition-transform duration-900">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="2"
          stroke="currentColor"
          class="size-6">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"
          ></path>
        </svg>
        <span class="font-semibold text-xl">Mail schreiben</span>
      </div>
    </a>
  </div>
</div>
<!-- Scroll Up Button -->
<a
  id="scroll-up-button"
  href="#"
  class="invisible pointer-events-none bg-white text-[#004e7a] p-4 transition-all duration-900
  rounded-full fixed right-0 bottom-4 z-50 flex items-center border border-[#004e7a] translate-[-5px]">
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke-width="2"
    stroke="currentColor"
    class="size-6">
    <path
      fill-rule="evenodd"
      d="M11.47 7.72a.75.75 0 0 1 1.06 0l7.5 7.5a.75.75 0 1 1-1.06 1.06L12 9.31l-6.97 6.97a.75.75 0 0 1-1.06-1.06l7.5-7.5Z"
      clip-rule="evenodd"></path>
  </svg>
</a>

<script>
  const actions = document.getElementById("floating-actions");
  const scrollUpButton = document.getElementById("scroll-up-button");
  const threshold = Number(actions?.dataset.prop ?? 0);

  const shouldShowActions = () => threshold <= 0 || window.scrollY > threshold;

  const updateActions = () => {
    if (!actions) return;

    if (shouldShowActions()) {
      actions.classList.remove(
        "invisible",
        "pointer-events-none",
        "opacity-0",
        "duration-300",
      );
      actions.classList.add("opacity-100", "duration-600");
    } else {
      actions.classList.remove("opacity-100");
      actions.classList.add("opacity-0");
      setTimeout(() => {
        if (window.scrollY < threshold) {
          actions.classList.add("invisible", "pointer-events-none");
        }
      }, 300);
    }
  };

  const updateScrollUpButton = () => {
    if (!scrollUpButton) return;

    if (window.scrollY > 300) {
      scrollUpButton.classList.remove(
        "invisible",
        "pointer-events-none",
        "opacity-0",
      );
      scrollUpButton.classList.add("opacity-100");
    } else {
      scrollUpButton.classList.remove("opacity-100");
      scrollUpButton.classList.add("opacity-0");
      setTimeout(() => {
        if (window.scrollY < 300) {
          scrollUpButton.classList.add("invisible", "pointer-events-none");
        }
      }, 300);
    }
  };

  scrollUpButton?.addEventListener("click", (e) => {
    e.preventDefault();
    window.scrollTo({ top: 0, behavior: "smooth" });
  });

  window.addEventListener("scroll", () => {
    updateActions();
    updateScrollUpButton();
  });

  updateActions();
  updateScrollUpButton();
</script>
